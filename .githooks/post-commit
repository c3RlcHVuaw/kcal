#!/usr/bin/env sh
set -eu

branch="$(git branch --show-current)"
if [ -z "$branch" ]; then
  echo "post-commit: detached HEAD, skipping auto-push." >&2
  exit 0
fi

if ! git remote get-url origin >/dev/null 2>&1; then
  echo "post-commit: origin is not configured, skipping auto-push." >&2
  exit 0
fi

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  git push
else
  git push -u origin "$branch"
fi
